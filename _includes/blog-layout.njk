---
layout: base
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "url": "https://www.foundonchat.com{{ page.url }}",
  "datePublished": "{{ page.date.toISOString() }}",
  "author": {
    "@type": "Organization",
    "name": "FoundOnChat"
  },
  "publisher": {
    "@type": "Organization",
    "name": "FoundOnChat"
  }
}
</script>

<section class="blog-post">
    <h2>{{ title }}</h2>
    <p class="blog-date">Published: {{ page.date | readableDate }}</p>
    <div class="blog-content">
        {{ content | safe }}
    </div>
</section>

<section>
    <p><a href="/blog/">&larr; Back to all posts</a></p>
</section>